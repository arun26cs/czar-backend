# ─── Czar Backend — Local Environment Variables ───────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.
# Production uses GCP Secret Manager for all values marked [SECRET MANAGER].

# ─── PostgreSQL (local Docker) ────────────────────────────────────────────────
POSTGRES_ADMIN_PASSWORD=czar_admin_local
DB_AUTH_PASSWORD=czar_auth_pass
DB_USER_PASSWORD=czar_user_pass
DB_PLANNER_PASSWORD=czar_planner_pass

# ─── GCP / Pub/Sub Emulator ───────────────────────────────────────────────────
GCP_PROJECT_ID=czar-local
# PUBSUB_EMULATOR_HOST is set per-service in docker-compose.yml (pubsub-emulator:8085)
# For running services directly on host (outside Docker), set:
# PUBSUB_EMULATOR_HOST=localhost:9085

# ─── Phase 3 — Auth Service ───────────────────────────────────────────────────
# RSA key pair: run `bash scripts/generate-keys.sh` to generate local keys.
# Keys are stored in czar-auth/src/main/resources/keys/ (gitignored).
# In production, keys live in GCP Secret Manager (czar-auth-private-key).

# SendGrid — email OTP delivery (free tier: 100 emails/day, no credit card needed)
# Sign up at https://sendgrid.com → Settings → API Keys → Mail Send permission only
# Leave blank to use console log fallback in local dev
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx
SENDGRID_FROM_ADDRESS=noreply@czar.app

# Google OAuth2 — register at https://console.cloud.google.com
# APIs & Services → Credentials → OAuth 2.0 Client IDs → Web application
# Authorized redirect URI: http://localhost:8081/login/oauth2/code/google
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# GitHub OAuth2 — register at https://github.com/settings/developers → New OAuth App
# Homepage URL: http://localhost:8081
# Callback URL: http://localhost:8081/login/oauth2/code/github
GITHUB_CLIENT_ID=Ov23lixxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Phase 7 — Voice AI Service [SECRET MANAGER in prod] ─────────────────────
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# ─── Phase 8 — Notification Service [SECRET MANAGER in prod] ─────────────────
# Firebase project ID (for FCM push)
FIREBASE_PROJECT_ID=czar-local
# FIREBASE_ADMIN_SDK_JSON=<path to firebase-adminsdk.json — for local only>

# ─── Service-to-service URLs (override when running outside Docker) ───────────
# CZAR_PLANNER_BASE_URL=http://localhost:8083
# CZAR_USER_BASE_URL=http://localhost:8082

# ─── Internal Service Auth Token [SECRET MANAGER in prod] ────────────────────
# Shared secret used for service-to-service calls (/internal/** endpoints).
# Generate a strong random value for production: openssl rand -hex 32
CZAR_INTERNAL_SERVICE_TOKEN=czar-internal-dev-token
